{%- comment -%}
  A/B Test — Variant B CSS Overrides
  Injected as the first section in all *-b product templates.
  Fixes mobile sticky bar and tightens mobile layout.
{%- endcomment -%}

{% stylesheet %}
  /* ── B Variant: Always-visible sticky bar ── */

  /* Force the bar to be visible at all times (not just after scrolling past buy button) */
  sticky-add-to-cart[data-variant-available='true'] .sticky-add-to-cart__bar {
    opacity: 1 !important;
    transform: translateX(-50%) translateY(0%) !important;
    display: block !important;
  }

  /* Mobile: show full "Add to Cart" text, not icon-only */
  @media screen and (max-width: 749px) {
    .sticky-add-to-cart__bar .add-to-cart-text__content {
      display: inline !important;
    }

    .sticky-add-to-cart__button {
      width: auto !important;
      min-width: 120px !important;
      padding-inline: var(--padding-lg) !important;
    }

    .sticky-add-to-cart__bar {
      gap: var(--gap-sm) !important;
    }

    @media screen and (max-width: 390px) {
      .sticky-add-to-cart__image {
        display: none;
      }
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PDP B Overrides",
  "settings": []
}
{% endschema %}
