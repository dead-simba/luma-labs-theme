{%- unless section.settings.is_hidden or template.name == 'product' -%}
<div class="glowve-ann" id="glowveAnn">
  <div class="glowve-ann__shimmer" aria-hidden="true"></div>
  <div class="glowve-ann__stars" aria-hidden="true"></div>

  <div class="glowve-ann__inner">

    <div class="glowve-ann__badge">
      <span class="glowve-ann__badge-spark">✨</span>
      <span class="glowve-ann__badge-label">Big News</span>
    </div>

    <div class="glowve-ann__body">
      <span class="glowve-ann__headline">Luma Labs is now <em>Glowvé</em></span>
      <span class="glowve-ann__divider" aria-hidden="true">—</span>
      <span class="glowve-ann__sub">Same formula. Packaging got a massive glow-up.</span>
    </div>

    <a href="https://glowve.skin" class="glowve-ann__cta" id="glowveAnnLink" rel="noopener noreferrer">
      Shop the new look →
    </a>

    <button class="glowve-ann__close" id="glowveAnnClose" type="button" aria-label="Close announcement">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

  </div>
</div>

<script>
  (function () {
    var KEY = 'gla_dismissed_v2';
    var ann = document.getElementById('glowveAnn');
    if (!ann) return;

    if (localStorage.getItem(KEY)) {
      ann.remove();
      return;
    }

    // Pin banner directly below the sticky nav
    function pinBelowNav() {
      var nav = document.querySelector('sticky-header') ||
                document.querySelector('.header-wrapper') ||
                document.querySelector('[class*="site-header"]') ||
                document.querySelector('header');
      if (nav) ann.style.top = nav.offsetHeight + 'px';
    }
    pinBelowNav();
    window.addEventListener('resize', pinBelowNav);

    document.getElementById('glowveAnnClose').addEventListener('click', function () {
      ann.classList.add('glowve-ann--out');
      localStorage.setItem(KEY, '1');
      setTimeout(function () { ann.remove(); }, 420);
    });

    var going = false;
    document.getElementById('glowveAnnLink').addEventListener('click', function (e) {
      if (going) return;
      going = true;
      e.preventDefault();
      var href = this.href;
      document.body.style.transition = 'opacity 0.32s ease';
      document.body.style.opacity = '0';
      setTimeout(function () { window.location.href = href; }, 330);
    });
  })();
</script>
{%- endunless -%}

{% stylesheet %}
  .glowve-ann {
    position: sticky;
    top: 0;
    z-index: 98;
    overflow: hidden;
    background: linear-gradient(110deg, #F04C1A 0%, #E83860 40%, #C02E74 72%, #8E1858 100%);
    max-height: 200px;
    transition: max-height 0.42s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.42s ease;
  }

  .glowve-ann--out {
    max-height: 0 !important;
    opacity: 0;
    pointer-events: none;
  }

  .glowve-ann__shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 25%, rgba(255,255,255,0.12) 50%, transparent 75%);
    animation: gla-shimmer 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes gla-shimmer {
    0%   { transform: translateX(-120%) skewX(-12deg); }
    100% { transform: translateX(260%) skewX(-12deg); }
  }

  .glowve-ann__stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(circle, rgba(255,255,255,0.6) 1px, transparent 1px),
      radial-gradient(circle, rgba(255,255,255,0.4) 1px, transparent 1px),
      radial-gradient(circle, rgba(255,255,255,0.3) 1px, transparent 1px);
    background-size: 200px 64px, 130px 48px, 95px 36px;
    background-position: 24px 16px, 70px 32px, 12px 6px;
    opacity: 0.55;
  }

  .glowve-ann__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    padding: 16px 68px 16px 24px;
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
    flex-wrap: wrap;
  }

  .glowve-ann__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 100px;
    padding: 4px 12px 4px 8px;
    flex-shrink: 0;
    backdrop-filter: blur(6px);
  }

  .glowve-ann__badge-spark {
    font-size: 14px;
    display: inline-block;
    animation: gla-spark 2.2s ease-in-out infinite;
  }

  @keyframes gla-spark {
    0%, 100% { transform: scale(1) rotate(0deg); }
    40%       { transform: scale(1.35) rotate(14deg); }
    60%       { transform: scale(1.1) rotate(-6deg); }
  }

  .glowve-ann__badge-label {
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
  }

  .glowve-ann__body {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .glowve-ann__headline {
    font-size: 15.5px;
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    white-space: nowrap;
  }

  .glowve-ann__headline em {
    font-style: italic;
    color: #FFE08A;
  }

  .glowve-ann__divider {
    color: rgba(255, 255, 255, 0.35);
    font-size: 16px;
  }

  .glowve-ann__sub {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.3;
    white-space: nowrap;
  }

  .glowve-ann__cta {
    display: inline-flex;
    align-items: center;
    background: #fff;
    color: #8E1858;
    padding: 9px 22px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: 0.02em;
    flex-shrink: 0;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    animation: gla-pulse 2.8s ease-in-out infinite;
  }

  @keyframes gla-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.55); }
    50%       { box-shadow: 0 0 0 8px rgba(255,255,255,0); }
  }

  .glowve-ann__cta:hover {
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.25);
    animation: none;
    color: #6E1040;
  }

  .glowve-ann__close {
    position: absolute;
    right: 18px;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.85);
    cursor: pointer;
    padding: 7px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
    line-height: 0;
    flex-shrink: 0;
  }

  .glowve-ann__close:hover {
    background: rgba(255, 255, 255, 0.28);
    color: #fff;
    transform: translateY(-50%) rotate(90deg);
  }

  @media screen and (max-width: 900px) {
    .glowve-ann__sub,
    .glowve-ann__divider {
      display: none;
    }

    .glowve-ann__inner {
      gap: 12px;
      padding: 14px 56px 14px 16px;
    }
  }

  @media screen and (max-width: 600px) {
    .glowve-ann__badge {
      display: none;
    }

    .glowve-ann__headline {
      font-size: 13.5px;
    }

    .glowve-ann__cta {
      font-size: 12.5px;
      padding: 8px 16px;
    }

    .glowve-ann__inner {
      gap: 10px;
      padding: 13px 48px 13px 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Glowvé Migration Banner",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "is_hidden",
      "label": "Hide banner",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Glowvé Migration Banner"
    }
  ]
}
{% endschema %}
