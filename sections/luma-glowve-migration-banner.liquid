{%- unless section.settings.is_hidden -%}
<div class="glowve-ann" id="glowveAnn">
  <div class="glowve-ann__shimmer" aria-hidden="true"></div>
  <div class="glowve-ann__stars" aria-hidden="true"></div>

  <div class="glowve-ann__inner">

    <div class="glowve-ann__badge">
      <span class="glowve-ann__badge-spark">✨</span>
      <span class="glowve-ann__badge-label">Big News</span>
    </div>

    <div class="glowve-ann__body">
      <span class="glowve-ann__headline">Luma Labs is now <em>Glowvé</em></span>
      <span class="glowve-ann__divider" aria-hidden="true">—</span>
      <span class="glowve-ann__sub">Same formula. Packaging got a massive glow-up.</span>
    </div>

    <a href="https://glowve.skin" class="glowve-ann__cta" id="glowveAnnLink" rel="noopener noreferrer">
      Shop the new look →
    </a>

    <button class="glowve-ann__close" id="glowveAnnClose" type="button" aria-label="Close announcement">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

  </div>
</div>

<script>
  (function () {
    var KEY = 'gla_dismissed_v2';
    var ann = document.getElementById('glowveAnn');
    if (!ann) return;

    if (localStorage.getItem(KEY)) {
      ann.remove();
      return;
    }

    document.getElementById('glowveAnnClose').addEventListener('click', function () {
      ann.classList.add('glowve-ann--out');
      localStorage.setItem(KEY, '1');
      setTimeout(function () { ann.remove(); }, 420);
    });

    var going = false;
    document.getElementById('glowveAnnLink').addEventListener('click', function (e) {
      if (going) return;
      going = true;
      e.preventDefault();
      var href = this.href;
      document.body.style.transition = 'opacity 0.32s ease';
      document.body.style.opacity = '0';
      setTimeout(function () { window.location.href = href; }, 330);
    });
  })();
</script>
{%- endunless -%}

{% stylesheet %}
  .glowve-ann {
    position: sticky;
    top: 0;
    z-index: 9999;
    overflow: hidden;
    background: linear-gradient(100deg, #0e0900 0%, #c49030 22%, #d95848 55%, #bf3870 82%, #8b2060 100%);
    max-height: 200px;
    transition: max-height 0.42s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.42s ease;
  }

  .glowve-ann--out {
    max-height: 0 !important;
    opacity: 0;
    pointer-events: none;
  }

  .glowve-ann__shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,0.1) 50%, transparent 70%);
    animation: gla-shimmer 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes gla-shimmer {
    0%   { transform: translateX(-100%) skewX(-15deg); }
    100% { transform: translateX(250%) skewX(-15deg); }
  }

  .glowve-ann__stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(circle, rgba(255,255,255,0.55) 1px, transparent 1px),
      radial-gradient(circle, rgba(255,255,255,0.35) 1px, transparent 1px),
      radial-gradient(circle, rgba(255,255,255,0.25) 1px, transparent 1px);
    background-size: 180px 60px, 120px 45px, 90px 35px;
    background-position: 20px 15px, 60px 30px, 10px 5px;
    opacity: 0.6;
  }

  .glowve-ann__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    padding: 18px 68px 18px 24px;
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
    flex-wrap: wrap;
  }

  .glowve-ann__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 100px;
    padding: 4px 12px 4px 8px;
    flex-shrink: 0;
    backdrop-filter: blur(4px);
  }

  .glowve-ann__badge-spark {
    font-size: 15px;
    display: inline-block;
    animation: gla-spark 2.2s ease-in-out infinite;
  }

  @keyframes gla-spark {
    0%, 100% { transform: scale(1) rotate(0deg); }
    40%       { transform: scale(1.3) rotate(12deg); }
    60%       { transform: scale(1.1) rotate(-5deg); }
  }

  .glowve-ann__badge-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
  }

  .glowve-ann__body {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .glowve-ann__headline {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    white-space: nowrap;
  }

  .glowve-ann__headline em {
    font-style: italic;
    color: #ffd580;
  }

  .glowve-ann__divider {
    color: rgba(255, 255, 255, 0.4);
    font-size: 16px;
  }

  .glowve-ann__sub {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.3;
    white-space: nowrap;
  }

  .glowve-ann__cta {
    display: inline-flex;
    align-items: center;
    background: #fff;
    color: #1a0a00;
    padding: 10px 22px;
    border-radius: 100px;
    font-size: 13.5px;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: 0.02em;
    flex-shrink: 0;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    animation: gla-pulse 2.8s ease-in-out infinite;
  }

  @keyframes gla-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.5); }
    50%       { box-shadow: 0 0 0 7px rgba(255,255,255,0); }
  }

  .glowve-ann__cta:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.3);
    animation: none;
  }

  .glowve-ann__close {
    position: absolute;
    right: 18px;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: rgba(255, 255, 255, 0.8);
    cursor: pointer;
    padding: 7px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
    line-height: 0;
    flex-shrink: 0;
  }

  .glowve-ann__close:hover {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
    transform: translateY(-50%) rotate(90deg);
  }

  @media screen and (max-width: 900px) {
    .glowve-ann__sub,
    .glowve-ann__divider {
      display: none;
    }

    .glowve-ann__inner {
      gap: 12px;
      padding: 16px 56px 16px 16px;
    }
  }

  @media screen and (max-width: 600px) {
    .glowve-ann__badge {
      display: none;
    }

    .glowve-ann__headline {
      font-size: 14px;
    }

    .glowve-ann__cta {
      font-size: 12.5px;
      padding: 9px 18px;
    }

    .glowve-ann__inner {
      gap: 10px;
      padding: 14px 50px 14px 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Glowvé Migration Banner",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "is_hidden",
      "label": "Hide banner",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Glowvé Migration Banner"
    }
  ]
}
{% endschema %}
