{%- liquid
  assign glowve_url = 'https://glowve.skin'
  case product.handle
    when 'alpha-arbutin'
      assign glowve_url = 'https://glowve.skin/products/fade-theory'
    when 'matte-uv-defense'
      assign glowve_url = 'https://glowve.skin/products/daylite-spf-50-sunscreen'
    when 'barrier-renew'
      assign glowve_url = 'https://glowve.skin/products/soft-reset-moisturizer'
  endcase
-%}

<div class="glowve-pdp">
  <div class="glowve-pdp__shimmer" aria-hidden="true"></div>
  <div class="glowve-pdp__inner">
    <span class="glowve-pdp__spark" aria-hidden="true">✨</span>
    <div class="glowve-pdp__copy">
      <strong class="glowve-pdp__headline">This product just got a glow-up.</strong>
      <span class="glowve-pdp__sub">Same formula, same results — now with stunning new packaging at Glowvé.</span>
    </div>
    <a
      href="{{ glowve_url }}"
      class="glowve-pdp__btn"
      id="glowvePdpBtn"
      rel="noopener noreferrer"
    >
      See it on Glowvé →
    </a>
  </div>
</div>

<script>
  (function () {
    var btn = document.getElementById('glowvePdpBtn');
    if (!btn) return;
    var going = false;
    btn.addEventListener('click', function (e) {
      if (going) return;
      going = true;
      e.preventDefault();
      var href = this.href;
      document.body.style.transition = 'opacity 0.32s ease';
      document.body.style.opacity = '0';
      setTimeout(function () { window.location.href = href; }, 330);
    });
  })();
</script>

{% stylesheet %}
  .glowve-pdp {
    position: relative;
    overflow: hidden;
    background: linear-gradient(90deg, #1a1205 0%, #c49a3c 28%, #d4615a 62%, #c44b78 100%);
  }

  .glowve-pdp__shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.12) 50%, transparent 100%);
    animation: gpdp-shimmer 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes gpdp-shimmer {
    from { transform: translateX(-100%); }
    to   { transform: translateX(220%); }
  }

  .glowve-pdp__inner {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 18px 28px;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  .glowve-pdp__spark {
    font-size: 26px;
    flex-shrink: 0;
    display: inline-block;
    animation: gpdp-spark 2.6s ease-in-out infinite;
    line-height: 1;
  }

  @keyframes gpdp-spark {
    0%, 100% { transform: scale(1) rotate(0deg); }
    50%       { transform: scale(1.22) rotate(8deg); }
  }

  .glowve-pdp__copy {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .glowve-pdp__headline {
    display: block;
    color: #fff;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.3;
  }

  .glowve-pdp__sub {
    display: block;
    color: rgba(255, 255, 255, 0.82);
    font-size: 13px;
    line-height: 1.45;
  }

  .glowve-pdp__btn {
    display: inline-flex;
    align-items: center;
    background: #fff;
    color: #1a1205;
    padding: 10px 22px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.02em;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .glowve-pdp__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.22);
  }

  @media screen and (max-width: 749px) {
    .glowve-pdp__inner {
      flex-wrap: wrap;
      padding: 16px;
      gap: 12px;
    }

    .glowve-pdp__btn {
      width: 100%;
      justify-content: center;
      padding: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Glowvé PDP Banner",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Glowvé PDP Banner"
    }
  ]
}
{% endschema %}
