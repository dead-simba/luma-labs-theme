{% doc %}
  @prompt
    generate for me a block where I can post 3-4 videos at a time 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-gallery-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-video-gallery__container-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-video-gallery__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-video-gallery__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-video-gallery__item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.video_background }};
  }

  .ai-video-gallery__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: #f4f4f4;
  }

  .ai-video-gallery__video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-video-gallery__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-video-gallery__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-gallery__caption-{{ ai_gen_id }} {
    padding: {{ block.settings.caption_padding }}px;
    text-align: {{ block.settings.caption_alignment }};
    color: {{ block.settings.caption_color }};
    font-size: {{ block.settings.caption_font_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-video-gallery__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<video-gallery-{{ ai_gen_id }}
  class="ai-video-gallery-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-gallery__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-video-gallery__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-video-gallery__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign video_url_key = 'video_url_' | append: i
          assign video_caption_key = 'video_caption_' | append: i
          assign video_url = block.settings[video_url_key]
          assign video_caption = block.settings[video_caption_key]
        %}

        {% if video_url != blank %}
          <div class="ai-video-gallery__item-{{ ai_gen_id }}">
            <div class="ai-video-gallery__video-wrapper-{{ ai_gen_id }}">
              {% if video_url contains 'youtube.com' or video_url contains 'youtu.be' %}
                {% liquid
                  assign video_id = ''
                  if video_url contains 'youtube.com/watch?v='
                    assign video_id = video_url | split: 'v=' | last | split: '&' | first
                  elsif video_url contains 'youtu.be/'
                    assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first
                  endif
                %}
                {% if video_id != blank %}
                  <iframe
                    class="ai-video-gallery__video-{{ ai_gen_id }}"
                    src="https://www.youtube.com/embed/{{ video_id }}"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                {% endif %}
              {% elsif video_url contains 'vimeo.com' %}
                {% liquid
                  assign video_id = video_url | split: 'vimeo.com/' | last | split: '/' | first
                %}
                {% if video_id != blank %}
                  <iframe
                    class="ai-video-gallery__video-{{ ai_gen_id }}"
                    src="https://player.vimeo.com/video/{{ video_id }}"
                    allow="autoplay; fullscreen; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                {% endif %}
              {% endif %}
            </div>
            {% if video_caption != blank %}
              <div class="ai-video-gallery__caption-{{ ai_gen_id }}">{{ video_caption }}</div>
            {% endif %}
          </div>
        {% else %}
          <div class="ai-video-gallery__item-{{ ai_gen_id }}">
            <div class="ai-video-gallery__video-wrapper-{{ ai_gen_id }}">
              <div class="ai-video-gallery__placeholder-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="5 3 19 12 5 21 5 3"></polygon>
                </svg>
              </div>
              <div class="ai-video-gallery__empty-state-{{ ai_gen_id }}">
                Add video {{ i }} URL
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</video-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('video-gallery-{{ ai_gen_id }}', VideoGallery{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Video gallery",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Video Gallery</p>"
