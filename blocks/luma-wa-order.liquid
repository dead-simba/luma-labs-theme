{%- doc -%}
  WhatsApp Order Button block for product pages.
  Pre-fills a WhatsApp message with product title, selected variant, price,
  and variant ID (for Make.com → Shopify draft order creation).
  Dynamically updates when the luma-bundle-selector changes the variant.
{%- enddoc -%}

{%- liquid
  assign wa_number = '923277771047'
  assign default_variant = product.selected_or_first_available_variant
-%}

<div class="luma-wa-order-wrapper" {{ block.shopify_attributes }}>
  <a
    id="luma-wa-order-btn-{{ block.id }}"
    href="https://wa.me/{{ wa_number }}?text={{ 'ORDER: ' | append: product.title | append: ' | ' | append: default_variant.title | append: ' | ' | append: default_variant.price | money | append: ' [vid:' | append: default_variant.id | append: ']' | url_encode }}"
    target="_blank"
    rel="noopener noreferrer"
    class="luma-wa-btn"
    aria-label="Order {{ product.title }} via WhatsApp"
  >
    <span class="luma-wa-btn__icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </span>
    <span class="luma-wa-btn__label">{{ block.settings.button_label }}</span>
  </a>
</div>

<script>
  (function () {
    var btn = document.getElementById('luma-wa-order-btn-{{ block.id }}');
    if (!btn) return;

    var waNumber = '{{ wa_number }}';
    var productTitle = {{ product.title | json }};

    // Pre-render all variants server-side to avoid client-side API calls
    var variantMap = {
      {% for variant in product.variants %}
        '{{ variant.id }}': {
          title: {{ variant.title | json }},
          price: {{ variant.price | money | json }},
          id: '{{ variant.id }}'
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    };

    function buildWaUrl(variantId) {
      var v = variantMap[variantId];
      if (!v) return btn.href;
      var msg = 'ORDER: ' + productTitle + ' | ' + v.title + ' | ' + v.price + ' [vid:' + v.id + ']';
      return 'https://wa.me/' + waNumber + '?text=' + encodeURIComponent(msg);
    }

    function updateButton(variantId) {
      btn.href = buildWaUrl(variantId);
    }

    // Listen for variant changes dispatched by luma-bundle-selector
    var idInput = document.querySelector('form[action^="/cart/add"] input[name="id"]');
    if (idInput) {
      idInput.addEventListener('change', function () {
        updateButton(this.value);
      });
      // Set initial state from whatever is checked on load
      updateButton(idInput.value);
    }
  })();
</script>

<style>
  .luma-wa-order-wrapper {
    width: 100%;
    margin-top: 8px;
  }

  .luma-wa-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background-color: #25D366;
    color: #ffffff;
    font-family: var(--font-body--family), sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 14px 20px;
    border-radius: 12px;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.1s ease;
    box-sizing: border-box;
  }

  .luma-wa-btn:hover {
    background-color: #1ebe5d;
    color: #ffffff;
    text-decoration: none;
  }

  .luma-wa-btn:active {
    transform: scale(0.98);
  }

  .luma-wa-btn__icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
</style>

{% schema %}
{
  "name": "WhatsApp Order Button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Order via WhatsApp"
    }
  ],
  "presets": [
    {
      "name": "WhatsApp Order Button",
      "category": "Product"
    }
  ]
}
{% endschema %}
